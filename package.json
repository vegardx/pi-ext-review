{
	"name": "pi-ext-review",
	"version": "0.1.0",
	"description": "pi.dev extension: multi-agent code review — seven specialist reviewers in parallel with dedupe and interactive walk-through",
	"keywords": [
		"pi-package",
		"pi-extension",
		"code-review",
		"multi-agent"
	],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/vegardx/pi-ext-review.git"
	},
	"type": "module",
	"engines": {
		"node": ">=20"
	},
	"pi": {
		"extensions": ["./index.ts"],
		"skills": ["./skills/"]
	},
	"peerDependencies": {
		"@mariozechner/pi-coding-agent": "*",
		"@sinclair/typebox": "*"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.13",
		"@mariozechner/pi-coding-agent": "^0.68.1",
		"@sinclair/typebox": "^0.34.49",
		"typescript": "^6.0.3",
		"vitest": "^3.2.4"
	},
	"scripts": {
		"typecheck": "tsc --noEmit",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"test": "vitest run",
		"check": "npm run lint && npm run typecheck && npm run test"
	}
}
